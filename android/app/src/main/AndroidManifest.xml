<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.emergency_resource_dispatch_system">

    <!-- 🔥 LOCATION PERMISSIONS -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION"/>
    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- Offline SMS fallback -->
    <uses-permission android:name="android.permission.SEND_SMS"/>

    <application
        android:label="SafeCall SOS"
        android:icon="@mipmap/ic_launcher"
        android:enableOnBackInvokedCallback="true">

        <!--
            ✅ GOOGLE MAPS API KEY
            Replace YOUR_GOOGLE_MAPS_API_KEY below with your real key.
            Get one at: https://console.cloud.google.com/
            Enable: Maps SDK for Android
        -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="AIzaSyDE2n9sQdYqugM7DmcBou_B0qCpVxN6JLg"/>

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|screenSize|smallestScreenSize|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">

            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
</manifest>